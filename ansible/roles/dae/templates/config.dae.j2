global {
  lan_interface: virbr0
  wan_interface: auto
  log_level: info
  allow_insecure: false
  auto_config_kernel_parameter: true
  check_interval: 30s
}

{% if dae_nodes is defined and dae_nodes | length > 0 %}
node {
  {% for node in dae_nodes %}
  '{{ node }}'
  {% endfor %}
}
{% endif %}

dns {
  upstream {
    alidns: 'udp://223.5.5.5:53'
    googledns: 'tcp://8.8.8.8:53'
  }
  routing {
    request {
      qname(keyword: taobao.com) -> alidns
      qname(keyword: tmall.com) -> alidns
      qname(keyword: alicdn.com) -> alidns
      qname(keyword: tbcache.com) -> alidns
      qname(keyword: golang.org) -> alidns
      qname(keyword: docker.io) -> alidns
      qname(keyword: docker.com) -> alidns
      qname(geosite:cn) -> alidns
      qname(geosite:google) -> googledns
      fallback: googledns
    }
    response {
      upstream(googledns) -> accept
      fallback: accept
    }
  }
}

group {
  proxy {
    filter: name(regex: '.*')
    policy: min_moving_avg
  }
}

routing {
  pname(NetworkManager) -> direct
  pname(sshd) -> direct
  
  # l4proto(udp) && dport(443) -> block

  l4proto(udp) && dport(123) -> direct

  dip(224.0.0.0/4, 255.255.255.255) -> direct

  domain(golang.org) -> direct
  domain(docker.io) -> direct
  domain(docker.com) -> direct

  domain(geosite:tencent) -> direct

  pname(wechat) -> direct
  domain(qq.com) -> direct
  domain(weixin.com) -> direct
  domain(qlogo.cn) -> direct

  domain(taifungbank.com) -> direct
  domain(epark-mo.com) -> direct
  domain(mnetwork.center) -> direct
  domain(ipinfo.io) -> direct
  domain(keyword: taobao.com) -> direct
  domain(keyword: tmall.com) -> direct
  domain(keyword: alicdn.com) -> direct
  domain(keyword: tbcache.com) -> direct
  domain(taobao.com) -> direct
  domain(tmall.com) -> direct
  domain(alicdn.com) -> direct
  domain(tbcache.com) -> direct

  domain(geosite:cn) -> direct
  dip(geoip:cn) -> direct
  dip(geoip:private) -> direct

  fallback: proxy
}
